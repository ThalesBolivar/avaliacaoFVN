# ============================================================
# Banco de Dados
# ============================================================
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=sistema_avaliacao
MYSQL_USER=avaliacao_user
MYSQL_PASSWORD=TROQUE_ESTA_SENHA
MYSQL_ROOT_PASSWORD=TROQUE_ESTA_SENHA_ROOT

# ============================================================
# JWT — gere com: openssl rand -hex 32
# ============================================================
SECRET_KEY=GERAR_COM_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================
# Redis
# ============================================================
REDIS_URL=redis://redis:6379/0

# ============================================================
# MinIO (Armazenamento de arquivos)
# ============================================================
MINIO_ENDPOINT=minio:9000
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin123
MINIO_SECURE=false
MINIO_BUCKET_DOCUMENTOS=documentos
MINIO_BUCKET_IMPORTACOES=importacoes

# ============================================================
# E-mail (opcional — notificações)
# ============================================================
SMTP_HOST=smtp.seudominio.com
SMTP_PORT=587
SMTP_USER=noreply@seudominio.com
SMTP_PASSWORD=TROQUE_ESTA_SENHA
EMAIL_FROM=noreply@sistema.com

# ============================================================
# Aplicação
# ============================================================
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
